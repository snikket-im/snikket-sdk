--dce full

--library datetime
--library haxe-strings
--library hsluv
--library tink_http
--library thenshim
--library HtmlParser
--library uuidv7
--library fractional-indexing

HaxeCBridge
borogove.Client
borogove.Push
borogove.persistence.Dummy
borogove.persistence.Sqlite
borogove.persistence.MediaStoreFS
borogove.Html

--cpp cpp
-D analyzer-optimize
-D NO_OMEMO
-D HXCPP_ALIGN_ALLOC
-D HXCPP_CPP17
-D HaxeCBridge.name=borogove
-D dll_link
-D HAXE_OUTPUT_FILE=libborogove
